DISCORD_TOKEN=replace_me
# 開發期建議先填一個測試伺服器 ID，指令同步會比較快
DEV_GUILD_ID=
# 預設通知頻道，啟動時自動 seed 的 watch 會用這個頻道
DEFAULT_CHANNEL_ID=
DATABASE_PATH=./data/bot.db
DEFAULT_INTERVAL_SEC=300
LOG_LEVEL=INFO

# 啟動時自動加入的監視目標，可留空。以逗號分隔。
SEED_WATCH_IDS=U1boLQqX,VrVHyWUk

# 可選：HTTP User-Agent
HTTP_USER_AGENT=PixeldrainDiscordWatchBot/1.0
